{
    "name": "brunocfalcao/eduka-installer",
    "description": "Eduka Installer",
    "keywords": [
        "brunocfalcao",
        "eduka"
    ],
    "homepage": "https://github.com/brunocfalcao/eduka-installer",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Bruno Falcão",
            "email": "bruno.c.falcao@brunofalcao.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.4|8.0"
    },
    "autoload": {
        "psr-4": {
            "Eduka\\Installer\\": "src"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eduka\\Installer\\EdukaInstallerServiceProvider"
            ]
        }
    }
}
